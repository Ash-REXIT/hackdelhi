{
  "name": "@tia/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../.env -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "dotenv -e ../.env -- node dist/index.js",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "db:push": "dotenv -e ../.env -- prisma db push",
    "db:seed": "dotenv -e ../.env -- tsx scripts/seedDatabase.ts",
    "db:reseed": "dotenv -e ../.env -- tsx scripts/seedDatabase.ts --reseed",
    "generate:test-cases": "dotenv -e ../.env -- tsx scripts/generateTestCases.ts",
    "db:studio": "dotenv -e ../.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@tia/shared": "*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "uuid": "^11.0.5",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^6.4.17",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/qrcode": "^1.5.5",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
