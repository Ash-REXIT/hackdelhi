# Database (local PostgreSQL — no Docker)
DATABASE_URL=postgresql://tia:tia_secret@localhost:5432/tia_db?schema=public

# For npm run setup — your PostgreSQL superuser password (postgres user)
POSTGRES_PASSWORD=

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=./uploads

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# AI Service
AI_SERVICE_URL=http://localhost:8000
GEMINI_API_KEY=

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FlowInvoice AI <noreply@flowinvoice.local>

# Seed — official TASC v2.1 database (place file in ./data/)
SEED_EXCEL_PATH=./data/TASC_Sample_Database_vF_payroll.xlsx
AUTO_INVOICE_CONFIDENCE_THRESHOLD=95
