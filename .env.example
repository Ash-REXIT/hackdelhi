# ── Docker (recommended — works after git clone) ───────────────────────────────
#   npm run start
#
# That one command starts: PostgreSQL, backend, AI service, Ollama + model, UI.
# First run may take 10–20 min (image build + ~4 GB model download).
#
# Postgres-only + local dev:
#   docker compose -f docker-compose.db.yml up -d
#   npm install && npm run setup:db && npm run dev

# Database (local dev only — Docker uses internal hostnames automatically)
DATABASE_URL=postgresql://tia:tia_secret@localhost:5432/tia_db?schema=public

# For npm run setup — your PostgreSQL superuser password (local Postgres install only)
POSTGRES_PASSWORD=

# Backend
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=./uploads

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# AI Service (Docker sets OLLAMA_BASE_URL=http://ollama:11434 automatically)
AI_SERVICE_URL=http://localhost:8000
GEMINI_API_KEY=
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FlowInvoice AI <noreply@flowinvoice.local>

# Seed — TASC file is committed in ./data/
SEED_EXCEL_PATH=./data/TASC_Sample_Database_vF_payroll.xlsx
AUTO_INVOICE_CONFIDENCE_THRESHOLD=95

# Voice input (Smallest.ai Pulse STT — client portal)
SMALLEST_AI_API_KEY=
