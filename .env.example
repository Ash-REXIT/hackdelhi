# FlowInvoice AI — Database Configuration

# Server
PORT=3001

# PostgreSQL (embedded auto-starts if USE_EMBEDDED_POSTGRES=true)
USE_EMBEDDED_POSTGRES=true
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=flowinvoice

# MySQL (install via scripts/install-mysql.ps1 or use local MySQL)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=flowinvoice
MYSQL_DB=flowinvoice_audit

# Set to false to skip MySQL if not installed
MYSQL_ENABLED=true
