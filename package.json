{
  "name": "flowinvoice-ai",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "FlowInvoice AI - TASC Hackathon",
  "workspaces": [
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently -n web,api,ai -c blue,green,magenta \"npm run dev:frontend\" \"npm run dev:backend\" \"npm run dev:ai\"",
    "dev:ai": "cd ai-service && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "dev:frontend": "vite",
    "dev:backend": "npm run dev -w backend",
    "build": "npm run build -w shared && npm run build -w backend && tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "db:generate": "npm run db:generate -w backend",
    "db:push": "npm run db:push -w backend",
    "db:seed": "npm run db:seed -w backend",
    "db:reseed": "npm run db:reseed -w backend",
    "generate:test-cases": "npm run generate:test-cases -w backend",
    "db:studio": "npm run db:studio -w backend",
    "env:sync": "npx tsx scripts/sync-env.ts",
    "setup:db": "npm run env:sync && npm run db:push && npm run db:seed",
    "setup:ai": "pip install -r ai-service/requirements-minimal.txt",
    "start": "docker compose up --build",
    "docker:start": "powershell -ExecutionPolicy Bypass -File scripts/docker-start.ps1",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up --build -d",
    "docker:db": "docker compose -f docker-compose.db.yml up -d",
    "seed:dispatch-demos": "npm run env:sync && dotenv -e .env -- npx tsx backend/scripts/seedDispatchDemos.ts"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.9.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.1.2",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
